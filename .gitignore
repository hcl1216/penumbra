# Penumbra -- raw data, checkpoints, and results live on Drive, NOT in git.
# Only small/derived artifacts and code belong in the repo.

# --- Data (raw + derived) ---
# Ignore everything under data/ EXCEPT the small tracked panel lists.
# (Must ignore data/* not data/ so the negations below can re-include a subdir.)
/data/*
!/data/panels/
/data/panels/*
!/data/panels/.gitkeep
# Track the small, authoritative panel name-lists + provenance (text only).
!/data/panels/*.tsv
!/data/panels/*.txt
!/data/panels/*.md
# ...but never the large raw spreadsheets (re-fetchable; URLs+sha256 in PROVENANCE.md).
/data/panels/*.xlsx
/data/panels/*.xls
_drive/
*.rds
*.h5
*.h5ad
*.loom
*.mtx
*.mtx.gz
*.csv.gz
*.tar.gz
*.zip
# CosMx flat-file outputs
*_exprMat_file.csv
*_metadata_file.csv
*_tx_file.csv
*_fov_positions_file.csv
*-polygons.csv

# --- Results / figures / verdicts (mirrored to Drive) ---
results/

# --- Model checkpoints / large artifacts ---
*.ckpt
*.pt
*.pth
*.pkl
*.joblib
*.npy
*.npz
*.parquet
*.feather

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
venv/
env/
.env

# --- OS / editor ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# --- Keep these (negate ignores) ---
!.gitkeep
